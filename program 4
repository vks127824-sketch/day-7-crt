#include <iostream>
using namespace std;

class Rectangle {
    public:
    int length;
    int width;
    
    Rectangle(){
        length = 10;
        width = 20;
    }
    
    Rectangle(int l){
    length = l;
    width = 30;
    }
    
    Rectangle(int l, int b){
        length = l;
        width = b;
    }
    void area() {
        cout << length * width << "\n";
    }
};

int main() {
    Rectangle r1;
    r1.area();
    Rectangle r2(5);
    r2.area();
    Rectangle r3(2,50);
    r3.area();
}
